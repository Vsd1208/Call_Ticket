# Local app server
PORT=3000
PUBLIC_BASE_URL=http://localhost:3000

# Google Gemini LLM — get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Dummy toll-free-style number for local demos only.
# This number is not callable until you replace it with a real provider number.
DUMMY_TOLL_FREE_NUMBER=+18005550199

# Live Twilio credentials. Leave blank for simulation mode.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Exotel trial details from your dashboard screenshot.
# Do not commit API keys, API tokens, account SID, or trial PIN.
EXOTEL_EXOPHONE=04048218468
EXOTEL_TRIAL_NUMBER=09513886363
EXOTEL_APP_ID=1230481
EXOTEL_SUBDOMAIN=api.exotel.com
EXOTEL_ACCOUNT_SID=
EXOTEL_API_KEY=
EXOTEL_API_TOKEN=

# Optional override. Defaults to:
# http://my.exotel.com/${EXOTEL_ACCOUNT_SID}/exoml/start_voice/${EXOTEL_APP_ID}
EXOTEL_FLOW_URL=
